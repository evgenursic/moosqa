# Direct Supabase connection string for Prisma CLI and schema changes
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Pooled Supabase connection string for the deployed app runtime
DATABASE_RUNTIME_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Used by Vercel Cron Jobs and any manual sync calls
CRON_SECRET="replace-with-a-long-random-secret"

# Separate admin/debug secret for private debug pages and manual weak-card reprocess
DEBUG_SECRET="replace-with-a-different-long-random-secret"

# Optional production alert delivery
DISCORD_ALERT_WEBHOOK_URL=""
SLACK_ALERT_WEBHOOK_URL=""
RESEND_API_KEY=""
ALERT_EMAIL_FROM=""
ALERT_EMAIL_TO=""

# Set this to your Vercel production URL or custom domain
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-nano"
