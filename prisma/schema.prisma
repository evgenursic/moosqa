// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReleaseSource {
  REDDIT
}

enum ReleaseType {
  SINGLE
  ALBUM
  EP
  PERFORMANCE
  LIVE_SESSION
  CHART
  ANNOUNCEMENT
  OTHER
}

enum ArtworkStatus {
  MISSING
  BASIC
  STRONG
}

enum GenreStatus {
  MISSING
  BASIC
  STRONG
}

enum LinkStatus {
  MISSING
  PARTIAL
  STRONG
}

enum AnalyticsEventType {
  OPEN
  LISTEN_CLICK
  VOTE
  SHARE
  REACTION_POSITIVE
  REACTION_NEGATIVE
}

enum ReleaseReactionValue {
  POSITIVE
  NEGATIVE
}

enum WorkflowRunStatus {
  SUCCESS
  FAILURE
  RUNNING
  CANCELLED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  RESOLVED
}

enum AlertDeliveryChannel {
  DISCORD
  SLACK
  EMAIL
}

enum UserRole {
  USER
  EDITOR
  ADMIN
}

enum FollowTargetType {
  ARTIST
  LABEL
  GENRE
}

model Release {
  id              String        @id @default(cuid())
  source          ReleaseSource @default(REDDIT)
  sourceItemId    String        @unique
  slug            String        @unique
  title           String
  artistName      String?
  projectTitle    String?
  releaseType     ReleaseType   @default(OTHER)
  flair           String?
  summary         String?
  aiSummary       String?
  outletName      String?
  labelName       String?
  genreName       String?
  genreConfidence Int           @default(0)
  releaseDate     DateTime?
  publishedAt     DateTime
  importedAt      DateTime      @default(now())
  metadataEnrichedAt DateTime?
  summarySourceTitle String?
  summarySourceExcerpt String?
  summaryQualityScore Int       @default(0)
  summaryQualityCheckedAt DateTime?
  updatedAt       DateTime      @updatedAt
  redditPermalink String
  sourceUrl       String
  imageUrl        String?
  thumbnailUrl    String?
  youtubeUrl      String?
  youtubeMusicUrl String?
  bandcampUrl     String?
  officialWebsiteUrl String?
  officialStoreUrl   String?
  artworkStatus   ArtworkStatus @default(MISSING)
  genreStatus     GenreStatus   @default(MISSING)
  linkStatus      LinkStatus    @default(MISSING)
  qualityScore    Int           @default(0)
  qualityCheckedAt DateTime?
  musicbrainzReleaseId String?
  musicbrainzArtistId  String?
  domain          String?
  score           Int?
  commentCount    Int?
  upvoteRatio     Float?
  awardCount      Int?
  crosspostCount  Int?
  rawJson         String?
  scoreAverage    Float         @default(0)
  scoreCount      Int           @default(0)
  openCount       Int           @default(0)
  listenClickCount Int          @default(0)
  shareCount      Int           @default(0)
  positiveReactionCount Int     @default(0)
  negativeReactionCount Int     @default(0)
  analyticsUpdatedAt DateTime?
  votes           Vote[]
  analyticsEvents AnalyticsEvent[]
  reactions       ReleaseReaction[]
  analyticsLocks  AnalyticsActionLock[]
  savedBy         UserSavedRelease[]

  @@index([publishedAt(sort: Desc)])
  @@index([releaseType, publishedAt(sort: Desc)])
  @@index([qualityScore(sort: Desc), publishedAt(sort: Desc)])
}

model UserProfile {
  id          String       @id
  email       String?      @unique
  displayName String?
  role        UserRole     @default(USER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  preferences UserPreference?
  savedReleases UserSavedRelease[]
  follows     UserFollow[]

  @@index([role, createdAt(sort: Desc)])
}

model UserPreference {
  userId             String      @id
  emailNotifications Boolean     @default(false)
  dailyDigest        Boolean     @default(false)
  weeklyDigest       Boolean     @default(true)
  instantAlerts      Boolean     @default(false)
  preferredGenres    Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSavedRelease {
  id        String      @id @default(cuid())
  userId    String
  releaseId String
  createdAt DateTime    @default(now())
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  release   Release     @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([userId, releaseId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([releaseId, createdAt(sort: Desc)])
}

model UserFollow {
  id              String           @id @default(cuid())
  userId          String
  targetType      FollowTargetType
  targetValue     String
  normalizedValue String
  createdAt       DateTime         @default(now())
  user            UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, normalizedValue])
  @@index([userId, targetType, createdAt(sort: Desc)])
  @@index([targetType, normalizedValue])
}

model Vote {
  id        String   @id @default(cuid())
  releaseId String
  deviceId  String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([releaseId, deviceId])
}

model AppState {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  releaseId  String?
  action     AnalyticsEventType
  platform   String?
  href       String?
  sourcePath String?
  deviceHash String?
  metadata   String?
  createdAt  DateTime           @default(now())
  release    Release?           @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([releaseId, createdAt(sort: Desc)])
}

model RateLimitEntry {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt(sort: Asc)])
}

model ReleaseReaction {
  id         String               @id @default(cuid())
  releaseId  String
  deviceHash String
  value      ReleaseReactionValue
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  release    Release              @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([releaseId, deviceHash])
  @@index([releaseId, value])
}

model AnalyticsActionLock {
  key        String             @id
  releaseId  String?
  action     AnalyticsEventType
  deviceHash String
  platform   String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  release    Release?           @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId, action, updatedAt(sort: Desc)])
  @@index([deviceHash, action, updatedAt(sort: Desc)])
}

model WorkflowRunState {
  workflowName  String            @id
  status        WorkflowRunStatus
  runUrl        String?
  branch        String?
  commitSha     String?
  details       String?
  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  updatedAt     DateTime          @updatedAt
}

model OpsAlert {
  key             String        @id
  severity        AlertSeverity
  status          AlertStatus   @default(OPEN)
  title           String
  message         String
  metricValue     Int?
  contextJson     String?
  firstTriggeredAt DateTime     @default(now())
  lastTriggeredAt DateTime      @default(now())
  lastNotifiedAt  DateTime?
  notificationCount Int         @default(0)
  resolvedAt      DateTime?
  updatedAt       DateTime      @updatedAt

  @@index([status, severity, updatedAt(sort: Desc)])
}

model AlertDeliveryLog {
  id            String               @id @default(cuid())
  alertKey      String?
  channel       AlertDeliveryChannel
  destination   String?
  success       Boolean              @default(false)
  isTest        Boolean              @default(false)
  responseStatus Int?
  latencyMs     Int?
  message       String?
  createdAt     DateTime             @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([channel, createdAt(sort: Desc)])
}
